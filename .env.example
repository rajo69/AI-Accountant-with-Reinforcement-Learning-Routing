# RL Routing Research Extension — Environment Variables
# Copy to .env and fill in values before running.

# ── Parent project (inherited) ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aiaccountant:localdev123@localhost:5432/aiaccountant
ANTHROPIC_API_KEY=

# ── RL training ──────────────────────────────────────────────────────────────
# Path to the trained PPO model file used by the LearnedRouter
MODEL_PATH=models/trained/ppo_variant_A.zip

# Total environment steps for PPO training (default from policy_config.yaml: 100000)
TRAINING_EPISODES=100000

# Number of episodes used for policy evaluation
EVAL_EPISODES=100

# Which reward variant to use: A (binary), B (workload-weighted), C (conservative)
REWARD_VARIANT=A

# Optional: S3/R2 URL to download the model file on startup (production approach)
# If set, api/main.py will download the model from this URL instead of MODEL_PATH
MODEL_S3_URL=
